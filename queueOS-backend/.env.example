PORT=5000

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017/queueos

# Redis connection
REDIS_URL=your_redis_host:your_redis_port
REDIS_HOST=your_redis_host
REDIS_PORT=your_redis_port
REDIS_PASSWORD=your_redis_password

# JWT secret — use a long random string in production
JWT_SECRET=your_jwt_secret_key

# Python ML service URL
ML_API_URL=http://localhost:8000

# Set to "production" in prod — enables secure cookies and HTTPS-only flags
NODE_ENV=development

# Optional queue config
REDIS_QUEUE_TTL_SECONDS=3600
REDIS_QUEUE_LOAD_LIMIT=1000
